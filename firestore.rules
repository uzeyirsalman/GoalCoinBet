rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "enversalman14@gmail.com";
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function getUserDataAfter(userId) {
      return getAfter(/databases/$(database)/documents/users/$(userId)).data;
    }

    function getBetData(betId) {
      return get(/databases/$(database)/documents/p2p_bets/$(betId)).data;
    }

    function getBetDataAfter(betId) {
      return getAfter(/databases/$(database)/documents/p2p_bets/$(betId)).data;
    }

    function isFutureEvent(eventId) {
      let event = get(/databases/$(database)/documents/events/$(eventId)).data;
      return event.status == "active" && (
        !(event.kickoff is string) ? request.time < event.kickoff : true
      );
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId && request.resource.data.balance == 250;
      
      allow update: if isAdmin() || (
        request.auth != null && request.auth.uid == userId && (
          // Case 1: No change in balance
          request.resource.data.balance == resource.data.balance
          
          // Case 2: Balance decrease (creation or acceptance of a bet)
          || (
            request.resource.data.balance < resource.data.balance &&
            request.resource.data.activeBetId != null &&
            (
              // Case 2a: User is creating a bet
              (
                getBetDataAfter(request.resource.data.activeBetId).creatorId == userId &&
                getBetDataAfter(request.resource.data.activeBetId).status == "pending" &&
                getBetDataAfter(request.resource.data.activeBetId).wager == resource.data.balance - request.resource.data.balance
              ) ||
              // Case 2b: User is accepting a bet
              (
                getBetDataAfter(request.resource.data.activeBetId).opponentId == userId &&
                getBetDataAfter(request.resource.data.activeBetId).status == "active" &&
                getBetData(request.resource.data.activeBetId).status == "pending" &&
                getBetDataAfter(request.resource.data.activeBetId).wager == resource.data.balance - request.resource.data.balance
              )
            )
          )
          
          // Case 3: Balance increase (refund of a pending bet)
          || (
            request.resource.data.balance > resource.data.balance &&
            request.resource.data.activeBetId != null &&
            (
              // Case 3a: User is getting refund because they cancelled or opponent declined
              getBetDataAfter(request.resource.data.activeBetId).creatorId == userId &&
              (getBetDataAfter(request.resource.data.activeBetId).status == "cancelled" || getBetDataAfter(request.resource.data.activeBetId).status == "declined") &&
              getBetData(request.resource.data.activeBetId).status == "pending" &&
              getBetDataAfter(request.resource.data.activeBetId).wager == request.resource.data.balance - resource.data.balance
            )
          )
        )
      );
    }

    match /events/{eventId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /solo_predictions/{predId} {
      allow read: if request.auth != null;
      // Allow creation if the user is predicting their own and the event kickoff is in the future
      allow create: if request.auth != null 
        && request.resource.data.userId == request.auth.uid
        && isFutureEvent(request.resource.data.eventId)
        && request.resource.data.status == "active";
        
      allow update, delete: if isAdmin() || (
        request.auth != null 
        && resource.data.userId == request.auth.uid
        && resource.data.status == "active"
        && get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.status == "active"
      );
    }

    match /p2p_bets/{betId} {
      allow read: if request.auth != null;
      
      allow create: if request.auth != null
        && request.resource.data.creatorId == request.auth.uid
        && request.resource.data.status == "pending"
        && isFutureEvent(request.resource.data.eventId)
        // Force the creator's balance update to happen in the same transaction and match the wager
        && getUserDataAfter(request.resource.data.creatorId).balance == getUserData(request.resource.data.creatorId).balance - request.resource.data.wager;

      allow update: if isAdmin() || (
        request.auth != null && (
          // Opponent accepting the challenge
          (
            request.auth.uid == resource.data.opponentId &&
            resource.data.status == "pending" &&
            request.resource.data.status == "active" &&
            isFutureEvent(resource.data.eventId) &&
            getUserDataAfter(resource.data.opponentId).balance == getUserData(resource.data.opponentId).balance - resource.data.wager
          ) ||
          // Opponent declining the challenge (refunds creator)
          (
            request.auth.uid == resource.data.opponentId &&
            resource.data.status == "pending" &&
            request.resource.data.status == "declined" &&
            getUserDataAfter(resource.data.creatorId).balance == getUserData(resource.data.creatorId).balance + resource.data.wager
          ) ||
          // Creator cancelling the challenge (refunds creator)
          (
            request.auth.uid == resource.data.creatorId &&
            resource.data.status == "pending" &&
            request.resource.data.status == "cancelled" &&
            getUserDataAfter(resource.data.creatorId).balance == getUserData(resource.data.creatorId).balance + resource.data.wager
          )
        )
      );
    }
  }
}
